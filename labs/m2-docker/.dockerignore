# .dockerignore — keep junk OUT of the build context (smaller, faster builds).
# The build context is everything sent to the Docker daemon; excluding caches and
# virtualenvs makes COPY faster and the image smaller. (Analogous to .gitignore.)
__pycache__/
*.pyc
.venv/
venv/
*.egg-info/
.pytest_cache/
.git/
.gitignore
*.md
# project-specific heavy/cache dirs (from your real app):
frozen/
pudbo_store/
*.parquet
*.log
.DS_Store
