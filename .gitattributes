# Normalize line endings: LF in the repo, native on checkout
* text=auto

# Keep these LF even on Windows (so WSL/bash + Docker don't choke on CRLF)
*.sh        text eol=lf
*.py        text eol=lf
*.tf        text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
Dockerfile  text eol=lf

# Binary proof artifacts (portfolio) — never normalize or diff
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.pdf   binary
*.parquet binary
*.mp4   binary
*.mov   binary
*.zip   binary
